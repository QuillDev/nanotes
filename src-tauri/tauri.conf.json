{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NaNotes",
  "version": "0.2.0",
  "identifier": "moe.quill.nanotes",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "NaNotes",
        "width": 560,
        "height": 760,
        "minWidth": 380,
        "minHeight": 480,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "minimizable": false,
        "maximizable": false,
        "acceptFirstMouse": true,
        "dragDropEnabled": false,
        "skipTaskbar": true,
        "visible": false,
        "visibleOnAllWorkspaces": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
